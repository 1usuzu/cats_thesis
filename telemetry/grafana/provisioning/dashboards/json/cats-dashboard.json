        {"expr": "cats_network_bandwidth_kbps{site=\"cloud\"}", "legendFormat": "Cloud BW"},
        {"expr": "cats_network_bandwidth_kbps{site=\"edge\"}", "legendFormat": "Edge BW"}
      ],
      "fieldConfig": {"defaults": {"unit": "kbps"}}
    },
    {
      "title": "Queue Depth per Site",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "cats_compute_queue_depth{site=\"cloud\"}", "legendFormat": "Cloud Queue"},
        {"expr": "cats_compute_queue_depth{site=\"edge\"}", "legendFormat": "Edge Queue"}
      ]
